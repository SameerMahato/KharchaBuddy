{
  "name": "kharchabuddy-ai-financial-os",
  "version": "1.0.0",
  "description": "AI Financial Operating System - Next-generation personal finance platform",
  "private": true,
  "workspaces": [
    "shared",
    "gateway",
    "services/*",
    "frontend"
  ],
  "scripts": {
    "install:all": "bash scripts/install-all.sh",
    "dev:all": "bash scripts/dev-all.sh",
    "test:all": "bash scripts/test-all.sh",
    "build:all": "bash scripts/build-all.sh",
    "push:all": "bash scripts/push-all.sh",
    "deploy:k8s": "bash scripts/deploy-k8s.sh",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "verify:infra": "bash scripts/verify-infrastructure.sh",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/kharchabuddy"
  },
  "keywords": [
    "fintech",
    "ai",
    "personal-finance",
    "expense-tracker",
    "budgeting",
    "microservices",
    "machine-learning"
  ],
  "author": "KharchaBuddy Team",
  "license": "MIT"
}
