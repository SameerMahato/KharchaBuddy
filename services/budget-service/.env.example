PORT=3003
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://admin:password123@localhost:27017/kharchabuddy?authSource=admin

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis123

# Kafka
KAFKA_BROKERS=localhost:9093
KAFKA_CLIENT_ID=budget-service
KAFKA_GROUP_ID=budget-service-group

# JWT
JWT_SECRET=your-secret-key-here

# Nudge Configuration
MAX_NUDGES_PER_DAY=3
NUDGE_THRESHOLD_WARNING=0.75
NUDGE_THRESHOLD_CRITICAL=0.90
