{
  "name": "@kharchabuddy/shared",
  "version": "1.0.0",
  "description": "Shared libraries for KharchaBuddy microservices",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"**/*.ts\""
  },
  "keywords": [
    "kharchabuddy",
    "shared",
    "microservices"
  ],
  "author": "KharchaBuddy Team",
  "license": "MIT",
  "dependencies": {
    "@sentry/node": "^7.100.0",
    "@sentry/profiling-node": "^7.100.0",
    "dotenv": "^16.4.0",
    "pino": "^8.17.0",
    "pino-pretty": "^10.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "typescript": "^5.3.3"
  }
