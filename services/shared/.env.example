# Shared Environment Variables Template
# Copy this file to .env in each service directory

# Service Configuration
NODE_ENV=development
SERVICE_NAME=service-name
SERVICE_PORT=3000

# Database - MongoDB
MONGO_URI=mongodb://admin:password123@mongodb:27017/kharchabuddy?authSource=admin

# Database - TimescaleDB
TIMESCALE_URI=postgresql://postgres:postgres123@timescaledb:5432/kharchabuddy_timeseries

# Cache - Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis123

# Event Bus - Kafka
KAFKA_BROKERS=kafka:9092
KAFKA_CLIENT_ID=kharchabuddy-service
KAFKA_GROUP_ID=kharchabuddy-consumers

# Authentication
JWT_SECRET=${JWT_SECRET}
JWT_REFRESH_SECRET=${JWT_REFRESH_SECRET}
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Monitoring
PROMETHEUS_PORT=9090
METRICS_ENABLED=true

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Sentry
SENTRY_DSN=${SENTRY_DSN}
SENTRY_ENVIRONMENT=${NODE_ENV}
SENTRY_TRACES_SAMPLE_RATE=0.1
